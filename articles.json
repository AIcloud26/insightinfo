<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Read the full article on Insightinfo">
    <title>Article - Insightinfo</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <a href="index.html" class="logo">
                <div class="logo-icon">I</div>
                Insight<span>info</span>
            </a>
            
            <div class="menu-toggle" onclick="toggleMenu()">
                <span></span>
                <span></span>
                <span></span>
            </div>
            
            <div class="nav-container" id="navContainer">
                <nav>
                    <ul class="nav">
                        <li><a href="index.html">All</a></li>
                        <li><a href="category.html?cat=technology">Technology</a></li>
                        <li><a href="category.html?cat=finance">Finance</a></li>
                        <li><a href="category.html?cat=ai-tools">AI Tools</a></li>
                        <li><a href="category.html?cat=health-lifestyle">Health & Lifestyle</a></li>
                    </ul>
                </nav>
                
                <div class="search-box">
                    <input type="text" placeholder="Search articles...">
                    <button type="submit">🔍</button>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container">
        <article class="article-detail" id="articleDetail">
            <div class="loading" id="loading"></div>
        </article>

        <!-- Related Articles -->
        <section class="mb-4" style="margin-top: 3rem;" id="relatedSection">
            <h2 class="mb-2">Related Articles</h2>
            <div class="article-grid" id="relatedGrid"></div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>About Insightinfo</h4>
                <p>Your trusted source for the latest insights in Technology, Finance, AI Tools, and Health & Lifestyle.</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="index.html">Home</a></li>
                    <li><a href="category.html?cat=technology">Technology</a></li>
                    <li><a href="category.html?cat=finance">Finance</a></li>
                    <li><a href="category.html?cat=ai-tools">AI Tools</a></li>
                    <li><a href="category.html?cat=health-lifestyle">Health & Lifestyle</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Legal</h4>
                <ul>
                    <li><a href="about.html">About Us</a></li>
                    <li><a href="privacy.html">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2025 Insightinfo. All rights reserved.</p>
        </div>
    </footer>

    <button class="back-to-top" id="backToTop" onclick="scrollToTop()">↑</button>

    <script>
        var categoryNames = {
            'technology': 'Technology',
            'finance': 'Finance',
            'ai-tools': 'AI Tools',
            'health-lifestyle': 'Health & Lifestyle'
        };

        function generateViews() {
            var views = Math.floor(Math.random() * 25000) + 5000;
            return views.toLocaleString();
        }

        function generateDate() {
            var today = new Date();
            var daysAgo = Math.floor(Math.random() * 30);
            var date = new Date(today);
            date.setDate(date.getDate() - daysAgo);
            return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        }

        function generateContent(article) {
            var catName = categoryNames[article.category];
            return '<p>In this comprehensive guide, we explore everything you need to know about this topic.</p>' +
                '<h2>Introduction</h2>' +
                '<p>The landscape of ' + catName.toLowerCase() + ' is rapidly evolving, and understanding the key concepts has never been more important. This article dives deep into the subject matter, providing you with actionable insights and expert analysis.</p>' +
                '<h2>Key Points</h2>' +
                '<ul>' +
                '<li><strong>Understanding the Basics:</strong> We\'ll start with foundational concepts that everyone should know.</li>' +
                '<li><strong>Current Trends:</strong> Learn about the latest developments shaping the industry.</li>' +
                '<li><strong>Practical Applications:</strong> Discover how to apply these insights in real-world scenarios.</li>' +
                '<li><strong>Future Outlook:</strong> Get a glimpse of what\'s coming next in this space.</li>' +
                '</ul>' +
                '<h2>Why This Matters</h2>' +
                '<p>' + article.excerpt + '</p>' +
                '<blockquote>"The key to success in ' + catName.toLowerCase() + ' is staying informed and adaptable. Those who embrace change will thrive."</blockquote>' +
                '<h2>Actionable Takeaways</h2>' +
                '<ol>' +
                '<li>Stay updated with the latest trends and developments</li>' +
                '<li>Apply these insights to your own projects or investments</li>' +
                '<li>Share your knowledge with others in your network</li>' +
                '<li>Continue learning through our recommended resources</li>' +
                '</ol>' +
                '<h2>Conclusion</h2>' +
                '<p>We hope this article has provided valuable insights. The world of ' + catName.toLowerCase() + ' continues to evolve, and staying informed is the key to success.</p>';
        }

        function renderArticle(article) {
            var container = document.getElementById('articleDetail');
            var loading = document.getElementById('loading');
            if (loading) loading.remove();
            
            var views = generateViews();
            var date = generateDate();
            var catName = categoryNames[article.category];
            
            container.innerHTML = 
                '<div class="article-hero">' +
                '<img src="' + article.image.replace('w=600&h=400', 'w=1200&h=600') + '" alt="' + article.title + '">' +
                '</div>' +
                '<div class="article-body">' +
                '<header class="article-header">' +
                '<span class="card-category">' + catName + '</span>' +
                '<h1>' + article.title + '</h1>' +
                '<div class="article-meta">' +
                '<span>📅 ' + date + '</span>' +
                '<span>👁 ' + views + ' views</span>' +
                '<span>⏱️ ' + article.readTime + '</span>' +
                '</div>' +
                '</header>' +
                '<div class="article-content">' +
                generateContent(article) +
                '</div>' +
                '<div class="article-tags">' +
                '<a href="category.html?cat=' + article.category + '" class="tag">' + catName + '</a>' +
                '<a href="#" class="tag">Trending</a>' +
                '<a href="#" class="tag">2025</a>' +
                '</div>' +
                '</div>';
            
            document.title = article.title + ' - Insightinfo';
        }

        function renderRelated(currentArticle, allArticles) {
            var related = allArticles.filter(function(a) { 
                return a.category === currentArticle.category && a.id !== currentArticle.id; 
            }).slice(0, 3);
            
            if (related.length === 0) {
                document.getElementById('relatedSection').style.display = 'none';
                return;
            }
            
            var grid = document.getElementById('relatedGrid');
            var html = '';
            
            for (var i = 0; i < related.length; i++) {
                var article = related[i];
                html += '<article class="article-card">' +
                    '<div class="card-image">' +
                    '<img src="' + article.image + '" alt="' + article.title + '" loading="lazy">' +
                    '</div>' +
                    '<div class="card-content">' +
                    '<span class="card-category">' + categoryNames[article.category] + '</span>' +
                    '<h3 class="card-title">' +
                    '<a href="article.html?id=' + article.id + '">' + article.title + '</a>' +
                    '</h3>' +
                    '<p class="card-excerpt">' + article.excerpt + '</p>' +
                    '<div class="card-meta">' +
                    '<span>📅 ' + generateDate() + '</span>' +
                    '<span>👁 ' + Math.floor(Math.random() * 15 + 5) + 'K views</span>' +
                    '</div>' +
                    '<a href="article.html?id=' + article.id + '" class="read-more-btn">Read More...</a>' +
                    '</div>' +
                    '</article>';
            }
            
            grid.innerHTML = html;
        }

        function toggleMenu() {
            var nav = document.getElementById('navContainer');
            if (nav) nav.classList.toggle('active');
        }

        window.addEventListener('scroll', function() {
            var btn = document.getElementById('backToTop');
            if (btn) btn.classList.toggle('visible', window.pageYOffset > 300);
        });

        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function loadArticle() {
            try {
                var response = await fetch('articles.json');
                var data = await response.json();
                var articles = data.articles;
                
                var urlParams = new URLSearchParams(window.location.search);
                var articleId = parseInt(urlParams.get('id')) || 1;
                
                var article = articles.find(function(a) { return a.id === articleId; }) || articles[0];
                
                renderArticle(article);
                renderRelated(article, articles);
            } catch (error) {
                console.error('Error:', error);
                var container = document.getElementById('articleDetail');
                if (container) {
                    container.innerHTML = '<p style="text-align: center; padding: 3rem;">Unable to load article. <a href="index.html">Return to homepage</a></p>';
                }
            }
        }

        document.addEventListener('DOMContentLoaded', loadArticle);
    </script>
</body>
</html>
